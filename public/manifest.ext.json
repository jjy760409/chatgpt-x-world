{
    "manifest_version": 3,
    "name": "ANW Zero-Click Scanner",
    "version": "1.0.0",
    "description": "Scan suspicious links and messages instantly from your browser.",
    "action": {
        "default_popup": "index.html",
        "default_title": "ANW Scanner"
    },
    "icons": {
        "16": "icon-192.png",
        "48": "icon-192.png",
        "128": "icon-512.png"
    },
    "permissions": [
        "activeTab",
        "storage"
    ]
}